# --- Groq (transcripción) — SOLO servidor, es secreta ---
# https://console.groq.com/keys
GROQ_API_KEY=gsk_tu_clave_aca

# --- Supabase (auth + base de datos) ---
# Panel de Supabase → Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --- Cron (purga de papelera) — SOLO servidor, es secreta ---
# Usado por /api/cron/purge para validar el request (header Authorization: Bearer o ?secret=).
CRON_SECRET=

# --- Supabase service role — SOLO servidor, es secreta, bypassea RLS ---
# Panel de Supabase → Project Settings → API Keys → service_role.
# Usada por /api/cron/purge (job de sistema, sin usuario logueado) para poder
# borrar filas vencidas de TODOS los usuarios. No exponer ni usar en el cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth Client (web) — pública, se expone al cliente ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs → tipo "Web application".
# Usada SOLO para "Exportar a Google Drive" (Google Identity Services, modelo de token, pedido
# on-demand al apretar el botón) — NO es el login de Google (ese usa Supabase Auth y no requiere
# esta variable). Agregá como "Authorized JavaScript origins" en ese mismo OAuth Client:
#   http://localhost:3000
#   https://audio-transcriber-web-kappa.vercel.app
# El scope usado (drive.file) es sensible: en modo "Testing" del OAuth consent screen funciona para
# vos y usuarios de prueba agregados a mano; para abrirlo a cualquier usuario, Google exige pasar
# su proceso de verificación.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
