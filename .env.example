# --- Groq (transcripción) — SOLO servidor, es secreta ---
# https://console.groq.com/keys
GROQ_API_KEY=gsk_tu_clave_aca

# --- Supabase (auth + base de datos) ---
# Panel de Supabase → Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --- Cron (purga de papelera) — SOLO servidor, es secreta ---
# Usado por /api/cron/purge para validar el request (header Authorization: Bearer o ?secret=).
CRON_SECRET=

# --- Supabase service role — SOLO servidor, es secreta, bypassea RLS ---
# Panel de Supabase → Project Settings → API Keys → service_role.
# Usada por /api/cron/purge (job de sistema, sin usuario logueado) para poder
# borrar filas vencidas de TODOS los usuarios. No exponer ni usar en el cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth Client (web) — pública, se expone al cliente ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs → tipo "Web application".
# Usada SOLO para "Exportar a Google Drive" (Google Identity Services, modelo de token, pedido
# on-demand al apretar el botón) — NO es el login de Google (ese usa Supabase Auth y no requiere
# esta variable). Agregá como "Authorized JavaScript origins" en ese mismo OAuth Client:
#   http://localhost:3000
#   https://audio-transcriber-web-kappa.vercel.app
# El scope usado (drive.file) es sensible: en modo "Testing" del OAuth consent screen funciona para
# vos y usuarios de prueba agregados a mano; para abrirlo a cualquier usuario, Google exige pasar
# su proceso de verificación.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Google OAuth offline (Drive-sync, server-side) — SOLO servidor, son secretas ---
# Mismo OAuth Client (tipo "Web application") que NEXT_PUBLIC_GOOGLE_CLIENT_ID de arriba.
# GOOGLE_CLIENT_ID puede repetir ese mismo Client ID (no es secreto en sí); GOOGLE_CLIENT_SECRET
# es NUEVO: Google Cloud Console → APIs & Services → Credentials → ese OAuth Client → "Client secret".
# Usados por /api/drive/connect + /api/drive/callback para el flujo OAuth OFFLINE
# (access_type=offline + refresh_token) que conecta Drive como nodo de sync — separado del login
# de Supabase y del export puntual (que usa NEXT_PUBLIC_GOOGLE_CLIENT_ID). Agregá como
# "Authorized redirect URIs" en ese mismo OAuth Client:
#   http://localhost:3000/api/drive/callback
#   https://audio-transcriber-web-kappa.vercel.app/api/drive/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Clave de cifrado del refresh token de Drive — SOLO servidor, es secreta ---
# 32 bytes en base64. Generala con: openssl rand -base64 32
# Usada por src/lib/crypto.ts (AES-256-GCM) para cifrar refresh_token_encrypted en
# drive_connections y para firmar el `state` anti-CSRF del flujo OAuth. Si se pierde o cambia,
# las conexiones de Drive existentes quedan indescifrables (hay que reconectar).
DRIVE_TOKEN_KEY=
